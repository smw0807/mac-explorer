{
  "name": "mac-explorer",
  "productName": "Mac Explorer",
  "version": "0.1.0",
  "description": "Windows Explorer style file manager for macOS",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && VITE_DEV=1 electron .\"",
    "build": "vite build",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --mac"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "build": {
    "appId": "com.minwoo.macexplorer",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "files": ["dist/**/*", "electron/**/*"],
    "directories": { "output": "release" }
  }
}
